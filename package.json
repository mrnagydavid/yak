{
  "name": "yak",
  "version": "0.1.0",
  "description": "Vocabulary trainer PWA",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint src/",
    "test": "vitest",
    "seed:pack": "node scripts/seed/pack.mjs",
    "seed:build": "pnpm seed:pack",
    "seed:audit-gloss": "node scripts/seed/audit-gloss.mjs",
    "seed:audit-subdefs": "node scripts/seed/audit-subdefs.mjs",
    "seed:audit-examples": "node scripts/seed/audit-examples.mjs",
    "seed:detect-token-synonyms": "node scripts/seed/detect-token-synonyms.mjs",
    "seed:legacy:fetch": "node scripts/seed/legacy/fetch-kelly.mjs && node scripts/seed/legacy/fetch-wiktionary.mjs",
    "seed:legacy:join": "node scripts/seed/legacy/join.mjs && node scripts/seed/legacy/flag.mjs",
    "seed:legacy:batch": "node scripts/seed/legacy/batch-for-cleanup.mjs",
    "seed:legacy:batch-senses": "node scripts/seed/legacy/batch-senses.mjs",
    "seed:legacy:batch-gloss": "node scripts/seed/legacy/batch-gloss.mjs",
    "seed:legacy:batch-token-synonyms": "node scripts/seed/legacy/batch-token-synonyms.mjs",
    "seed:legacy:batch-translations": "node scripts/seed/legacy/batch-translations.mjs",
    "seed:legacy:batch-split": "node scripts/seed/legacy/batch-split.mjs",
    "seed:legacy:batch-example-senses": "node scripts/seed/legacy/batch-example-senses.mjs",
    "seed:legacy:compile": "node scripts/seed/legacy/compile-layers.mjs",
    "seed:legacy:apply": "node scripts/seed/legacy/apply-decisions.mjs",
    "seed:legacy:stale": "node scripts/seed/legacy/stale.mjs",
    "seed:legacy:reconcile": "node scripts/seed/legacy/reconcile-stale.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "preact": "^10.29.2",
    "preact-router": "^4.1.2",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "fake-indexeddb": "^6.2.5",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}